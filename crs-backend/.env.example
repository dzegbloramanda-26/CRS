# ─── CRS Ghana Backend · Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values before deploying.
# NEVER commit .env to version control.

# Server
PORT=3000
NODE_ENV=production

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# Admin credentials (change immediately after first deploy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Database path (relative to project root)
DB_PATH=./db/crs.db

# File uploads (relative to project root)
UPLOAD_DIR=./public/uploads

# Frontend URL for CORS (your actual domain)
FRONTEND_URL=https://crs.org.gh

# Contact form notifications (optional)
NOTIFY_EMAIL=info@crs.org.gh
