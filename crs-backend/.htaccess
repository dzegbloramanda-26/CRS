# CRS Ghana — .htaccess for Hostinger Node.js
# ─────────────────────────────────────────────
# Place this in your application root directory.
# Hostinger's Node.js manager handles the proxy automatically,
# but this file adds security hardening.

# ── Security Headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Block direct access to sensitive files ────────────────────
<FilesMatch "(\.env|\.env\.example|package\.json|package-lock\.json|server\.js|init\.js|DEPLOY\.md|frontend-integration\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Block access to db folder ─────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^db/ - [F,L]
    RewriteRule ^node_modules/ - [F,L]
</IfModule>

# ── Optional: Restrict admin to specific IPs ──────────────────
# Uncomment and set your office IP to lock down /admin:
# <Location /admin>
#     Order deny,allow
#     Deny from all
#     Allow from 102.176.XXX.XXX   # your office IP
# </Location>
